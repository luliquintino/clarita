# backend/.env.example
# Copy this file to .env and fill in the values before starting the server.
# Variables marked [REQUIRED] must be set. Variables marked [OPTIONAL] have safe defaults.

# ─── Server ───────────────────────────────────────────────────────────────────

# [OPTIONAL] Application environment. Valid values: development | test | production
NODE_ENV=development

# [OPTIONAL] Port the API server listens on. Must match NEXT_PUBLIC_API_URL in the dashboard.
PORT=3005

# ─── Database ─────────────────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL connection string. Works with Neon (cloud) or a local instance.
# Example (local):  postgresql://postgres:password@localhost:5432/clarita
# Example (Neon):   postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/clarita

# ─── Authentication ───────────────────────────────────────────────────────────

# [REQUIRED] Secret used to sign JWT tokens. Must be at least 32 characters long.
# Generate one with: openssl rand -base64 32
JWT_SECRET=replace-with-a-random-secret-at-least-32-chars-long

# [OPTIONAL] JWT token expiration time. Examples: 7d, 24h, 60m
JWT_EXPIRES_IN=7d

# ─── File Uploads – Cloudinary ────────────────────────────────────────────────
# [OPTIONAL] Required only in production for cloud file uploads (exam attachments).
# In development, files are stored locally. Sign up at https://cloudinary.com.

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Email – Resend ───────────────────────────────────────────────────────────
# [OPTIONAL] Required only if you want transactional emails (invitations, password reset).
# Sign up at https://resend.com and verify your sending domain.

RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=CLARITA <noreply@yourdomain.com>

# ─── Web Push Notifications ───────────────────────────────────────────────────
# [OPTIONAL] Required only if you want browser push notifications.
# Generate a VAPID key pair with: npx web-push generate-vapid-keys

VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@yourdomain.com

# ─── CORS ─────────────────────────────────────────────────────────────────────

# [OPTIONAL] Allowed CORS origins, comma-separated. Use * to allow all origins in development.
CORS_ORIGIN=http://localhost:3000

# ─── Frontend URL ─────────────────────────────────────────────────────────────

# [OPTIONAL] Base URL of the frontend app. Used to build links inside emails.
FRONTEND_URL=http://localhost:3000

# ─── AI Engine – Digital Twin ─────────────────────────────────────────────────

# [OPTIONAL] URL of the AI/Digital Twin microservice. Required only if that feature is enabled.
AI_ENGINE_URL=http://localhost:5001

# ─── Memed – Digital Prescriptions ───────────────────────────────────────────
# [OPTIONAL] Required only if the digital prescriptions feature is enabled.
# Obtain credentials at https://memed.com.br.

MEMED_API_KEY=your-memed-api-key
MEMED_API_URL=https://api.memed.com.br/v1
