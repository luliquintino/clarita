# backend/.env.example
NODE_ENV=development
PORT=3005

# PostgreSQL (Neon ou local)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Cloudinary (upload de exames)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Resend (emails transacionais)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=CLARITA <noreply@yourdomain.com>

# Web Push (notificações push)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@yourdomain.com

# Frontend URL (para links de email)
FRONTEND_URL=http://localhost:3000

# CORS (origens permitidas, separadas por vírgula; use * para desenvolvimento)
CORS_ORIGIN=http://localhost:3000

# AI Engine (Digital Twin / análise de paciente)
AI_ENGINE_URL=http://localhost:5001

# Memed (prescrições digitais)
MEMED_API_KEY=your-memed-api-key
MEMED_API_URL=https://api.memed.com.br/v1

# SATEPSI (testes psicológicos aprovados pelo CFP)
SATEPSI_API_URL=https://satepsi.cfp.org.br/api/tests
