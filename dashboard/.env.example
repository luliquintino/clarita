# dashboard/.env.example
# Copy this file to .env.local and fill in the values before starting the dashboard.
# Variables marked [REQUIRED] must be set. Variables marked [OPTIONAL] have safe defaults.

# ─── API ──────────────────────────────────────────────────────────────────────

# [REQUIRED] Base URL of the Clarita backend API, including the /api path prefix.
# Must match the PORT configured in backend/.env (default: 3005).
NEXT_PUBLIC_API_URL=http://localhost:3005/api
